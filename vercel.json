{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/data?action=auto_violations",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/data?action=sync-kadwar",
      "schedule": "0 * * * *"
    }
  ]
}
